# AiChat 运行时配置
# Vite build 时把 VITE_* 前缀变量打包进客户端 bundle
# CI 按环境 (dev/staging/prod) 注入 VITE_AI_API_ENDPOINT 与 VITE_AI_AGENT_KEY
# 其余变量留空即可，代码内有默认值

# AI 调用 endpoint；未注入时代码默认 '/api/ai/v1/invoke'（同源代理）
VITE_AI_API_ENDPOINT=/api/ai/v1/invoke

# 账号渠道；未注入时代码默认 'lb'
VITE_AI_ACCOUNT_CHANNEL=lb

# 应用标识；未注入时代码默认 'longbridge'
VITE_AI_APP_ID=longbridge

# Agent 鉴权 key；无默认值，生产构建必须由 CI 注入
VITE_AI_AGENT_KEY=
